# ─────────────────────────────────────────────────────────────
#  TotalWare — environment variables
#  Copy this file to ".env" and fill in your own API keys.
#  The real .env is git-ignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────

# Threat intelligence API keys (all have free tiers)
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
SHODAN_API_KEY=your_shodan_api_key_here
OTX_API_KEY=your_alienvault_otx_api_key_here
ABUSE_CH_AUTH_KEY=your_abuse_ch_auth_key_here   # used by URLhaus + MalwareBazaar

# AI summary (Groq — free)
GROQ_API_KEY=your_groq_api_key_here

# Flask session secret (use a long random string in production)
SECRET_KEY=change-me-to-a-long-random-string

# Database (optional). Defaults to a local SQLite file if unset.
# For production, point this at PostgreSQL, e.g.:
# DATABASE_URL=postgresql://user:password@host:5432/totalware
# DATABASE_URL=
